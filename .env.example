# Скопируй этот файл в .env (или установи переменные через NSSM / systemd / PowerShell).
# Для разработки переменные читаются Node-ом из process.env напрямую — без библиотеки dotenv.

# Порт, на котором слушает сервер (за Cloudflare Tunnel доступен только локально).
PORT=8080

# Разрешённые Origin для WebSocket. Перечисли через запятую все домены, с которых
# браузер может подключаться. Для прод-деплоя ОБЯЗАТЕЛЬНО задать.
# Если оставить пустым — Origin не проверяется (только для локальной разработки).
ALLOWED_ORIGINS=https://dice.example.com,http://localhost:8080

# Максимум одновременно живых комнат — защита от создания тысяч пустых.
MAX_ROOMS=50
